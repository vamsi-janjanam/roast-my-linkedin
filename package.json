{
  "name": "linkedin-roaster",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Paste your LinkedIn profile, get a brutally honest roast powered by Claude.",
  "scripts": {
    "start": "npm run build && node server/index.js",
    "dev": "concurrently -k -n SERVER,VITE -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "serve": "node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.7"
  }
}
